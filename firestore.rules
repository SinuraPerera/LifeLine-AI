rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Pillar 1: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Pillar 2: User Profile Validation Helper (Anti-Update-Gap)
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email'])
        && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100;
    }

    // Pillar 2: Emergency Alert Validation Helper
    function isValidEmergencyAlert(data) {
      return data.keys().hasAll(['id', 'userId', 'timestamp', 'type', 'latitude', 'longitude', 'status', 'triageLevel'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.type is string && data.type.size() <= 100
        && data.latitude is number
        && data.longitude is number
        && data.status in ['active', 'resolved', 'dispatched']
        && data.triageLevel in ['low', 'medium', 'high', 'critical'];
    }

    // Pillar 6: Profile & PII Isolation
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data)
        && request.resource.data.email == resource.data.email // Immutable Email
        && request.resource.data.uid == resource.data.uid;     // Immutable UID
      allow delete: if false; // Retention protection
    }

    // Pillar 8: Secure Queries & Alerts Tracking
    match /alerts/{alertId} {
      // Protect document IDs
      allow get: if isSignedIn() && isValidId(alertId) && (
        resource.data.userId == request.auth.uid || resource.data.status == 'active'
      );
      
      // Enforce query filters on the server-side list queries
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || resource.data.status == 'active'
      );

      // Create validation
      allow create: if isSignedIn() && isValidId(alertId) && isValidEmergencyAlert(request.resource.data)
        && request.resource.data.userId == request.auth.uid;

      // Update validation - split into specific action branches
      allow update: if isSignedIn() && isValidId(alertId) && isValidEmergencyAlert(request.resource.data) && (
        // Action: Change status or triageLevel by the owner or responder
        (request.resource.data.userId == resource.data.userId 
          && request.resource.data.id == resource.data.id
          && request.resource.data.type == resource.data.type
          && request.resource.data.latitude == resource.data.latitude
          && request.resource.data.longitude == resource.data.longitude
          && request.resource.data.timestamp == resource.data.timestamp)
      );

      allow delete: if false; // Permanent legal records of SOS events
    }
  }
}
